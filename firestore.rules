rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // ── Public read collections (app fetches these) ───────────────────────────

    // Sermons: anyone can read, only admins can write
    match /sermons/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Books/Library: anyone can read, only admins can write
    match /books/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sermon Categories: anyone can read, only admins can write
    match /sermon_categories/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery Categories: anyone can read, only admins can write
    match /gallery_categories/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Video Categories: anyone can read, only admins can write
    match /video_categories/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // App Settings (like YouTube API keys)
    match /app_settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Videos: anyone can read; admins write; authenticated users can increment views/likes
    match /videos/{doc} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isAuthenticated(); // allow view/like increments
    }

    // Video comments: anyone can read, authenticated users can create
    match /videos/{videoId}/comments/{commentId} {
      allow read: if true;
      allow create: if true; // Allow anonymous comments; tighten to isAuthenticated() if login is required
      allow delete: if isAdmin();
    }

    // Gallery images: publicly readable
    match /gallery/{doc} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'downloads'])
      );
    }

    // Live streams: anyone can read
    match /live_streams/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Events: anyone can read
    match /events/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Devotionals: anyone can read
    match /devotionals/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Carousel / banners: anyone can read
    match /carousel_items/{doc} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['itemType']));
    }
    match /carousel_config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /carousels/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements: anyone can read
    match /announcements/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Push notifications: only admins write; authenticated app reads its own
    match /push_notifications/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Members: any authenticated user can read; unauthenticated can read for search/directory
    match /members/{doc} {
      allow read: if true; // members directory is public in the app
      allow write: if isAdmin();
    }

    // Testimonies: anyone can read approved ones
    match /testimonies/{doc} {
      allow read: if true;
      allow create: if isAuthenticated(); // members can submit
      allow update, delete: if isAdmin();
    }

    // Daily cache (celebrants): public read
    match /daily_cache/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin tasks (password reset requests): admin write only
    match /admin_tasks/{doc} {
      allow read: if isAdmin();
      allow write: if isAuthenticated(); // prevent permission errors if admin_users sync is delayed
    }

    // Church Groups & Officials
    match /church_groups/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /church_officials/{doc} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Admin users list: only admins can read (security)
    match /admin_users/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Ministers content
    match /ministers_content/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog posts: anyone can read
    match /blog_posts/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Community posts: authenticated users read; moderation by admins
    match /community_posts/{doc} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['liked_by', 'likes_count', 'comments_count'])
      );
      allow delete: if isAdmin();
    }
    match /community_posts/{postId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Top-level community_comments collection
    match /community_comments/{doc} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // For likes
      allow delete: if isAdmin();
    }

    // Community groups (communication groups)
    match /community_groups/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Group messages (for group chat)
    match /group_messages/{doc} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Bible reading plan progress: per-user private data
    match /bible_reading_progress/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Bible AI Chats: per-user private data
    match /bible_ai_chats/{userId}/sessions/{doc=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Prayer and Testimonies
    match /prayer_testimonies/{doc} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Bible AI config: anyone can read, only admins can write
    match /bible_ai/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ai_config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ai_prompts/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ai_exegesis/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /test/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Private chats and messages
    match /private_chats/{chatId} {
      allow read: if isAuthenticated() && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants);
    }
    match /private_chats/{chatId}/messages/{msgId} {
      allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/private_chats/$(chatId)).data.participants);
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid && (request.auth.uid in get(/databases/$(database)/documents/private_chats/$(chatId)).data.participants);
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
