rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Secure private chats media
    match /private_chats/{chatId}/messages/{fileName} {
      allow read, write: if request.auth != null && 
          request.auth.uid in firestore.get(/databases/(default)/documents/private_chats/$(chatId)).data.participants;
    }

    // Default rules for everything else (excluding private_chats)
    match /{folder}/{allPaths=**} {
      allow read: if folder != 'private_chats';
      allow write: if request.auth != null && folder != 'private_chats';
    }
    
    // Root level files
    match /{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
